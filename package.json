{
  "name": "@raniejade/rac",
  "version": "0.4.1",
  "description": "Install RAC project definitions into Claude/Codex/OpenCode config surfaces",
  "keywords": [
    "claude",
    "claude-code",
    "codex",
    "opencode",
    "mcp",
    "agent-config",
    "agents",
    "skills",
    "cli",
    "dotfiles"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "rac": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raniejade/rac.git"
  },
  "homepage": "https://github.com/raniejade/rac#readme",
  "bugs": {
    "url": "https://github.com/raniejade/rac/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "prepare": "npm run build",
    "prepublishOnly": "npm run lint && npm run typecheck && npm test && npm run build",
    "build": "tsup src/cli.ts --format esm --dts --clean --out-dir dist --splitting false",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:harness": "npm run build && node scripts/harness-smoke.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "diff": "^5.2.0",
    "fast-glob": "^3.3.3",
    "jsonc-parser": "^3.3.1",
    "liquidjs": "^10.17.0",
    "picocolors": "^1.1.1",
    "smol-toml": "^1.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.26.0",
    "@types/diff": "^7.0.2",
    "@types/node": "^22.15.3",
    "eslint": "^9.26.0",
    "eslint-plugin-import": "^2.31.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0",
    "vitest": "^2.1.1"
  }
}
