{
  "name": "rac",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "rac": "dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "tsup src/cli.ts --format esm --dts --clean --out-dir dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:harness": "npm run build && node scripts/harness-smoke.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fast-glob": "^3.3.3",
    "smol-toml": "^1.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^2.1.1",
    "eslint": "^9.26.0",
    "@eslint/js": "^9.26.0",
    "typescript-eslint": "^8.31.0",
    "eslint-plugin-import": "^2.31.0"
  }
}
